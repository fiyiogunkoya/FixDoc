        },
        {
          "type": "paragraph",
          "paragraph": {"rich_text": [{"plain_text": "The aws_iam_role trust policy was open to all principals."}]}
        },
        {
          "type": "heading_2",
          "heading_2": {"rich_text": [{"plain_text": "Fix/Mitigation"}]}
        },
        {
          "type": "paragraph",
          "paragraph": {"rich_text": [{"plain_text": "Restricted the assume_role_policy to only the specific service principal."}]}
        },
        {
          "type": "bulleted_list_item",
          "bulleted_list_item": {"rich_text": [{"plain_text": "Updated terraform aws_iam_role resource trust policy"}]}
        },
        {
          "type": "heading_2",
          "heading_2": {"rich_text": [{"plain_text": "Lessons Learned"}]}
        },
        {
          "type": "paragraph",
          "paragraph": {"rich_text": [{"plain_text": "Always scope trust policies to minimum required principals."}]}
        }
      ]
    },
